{{ ansible_managed | comment }}
# Header di sicurezza applicati a tutti i vhost.
# Includilo nei blocchi server con: include /etc/nginx/conf.d/security-headers.conf;
# oppure lascialo qui: nginx applica i "add_header" del contesto http anche ai server
# che non li ridefiniscono esplicitamente.

add_header X-Frame-Options "SAMEORIGIN" always;
add_header X-Content-Type-Options "nosniff" always;
add_header Referrer-Policy "strict-origin-when-cross-origin" always;
add_header X-XSS-Protection "0" always;
add_header Permissions-Policy "geolocation=(), microphone=(), camera=()" always;
{% if webserver_hsts %}
add_header Strict-Transport-Security "max-age=63072000; includeSubDomains" always;
{% endif %}

# Disabilita il listing delle directory
autoindex off;

# Nasconde i file "nascosti" (.git, .env, ecc.)
location ~ /\. {
    deny all;
    access_log off;
    log_not_found off;
}
