#!/bin/bash
{{ ansible_managed | comment }}
# Crea le collection Radicale mancanti leggendo il database di ispmail:
# rubrica e calendario personali per ogni mailbox, più rubrica e calendario
# condivisi per ogni dominio (di proprietà dell'utente fittizio
# "shared@dominio"; i permessi per gli utenti reali del dominio sono in
# /etc/radicale/rights).
# Radicale rilegge lo storage a ogni richiesta: niente restart necessario.
set -euo pipefail

COLLECTIONS=/var/lib/radicale/collections
ROOT=$COLLECTIONS/collection-root

# Radicale (utente "radicale") deve poter scrivere qui il suo lock file
install -d -o radicale -g radicale -m 700 "$COLLECTIONS" "$ROOT"

make_coll() { # $1=proprietario  $2=nome collection  $3=displayname  $4=tag DAV
  local dir="$ROOT/$1/$2"
  [ -d "$dir" ] && return 0
  install -d -o radicale -g radicale -m 700 "$ROOT/$1" "$dir"
  if [ "$4" = VCALENDAR ]; then
    printf '{"D:displayname": "%s", "tag": "VCALENDAR", "C:supported-calendar-component-set": "VEVENT,VTODO"}\n' "$3" > "$dir/.Radicale.props"
  else
    printf '{"D:displayname": "%s", "tag": "%s"}\n' "$3" "$4" > "$dir/.Radicale.props"
  fi
  chown radicale:radicale "$dir/.Radicale.props"
  chmod 600 "$dir/.Radicale.props"
  echo "creata collection $1/$2"
}

mysql -N mailserver -e 'SELECT email FROM virtual_users' | while read -r utente; do
  make_coll "$utente" contacts "Rubrica personale" VADDRESSBOOK
  make_coll "$utente" calendar "Calendario personale" VCALENDAR
done

mysql -N mailserver -e 'SELECT name FROM virtual_domains' | while read -r dominio; do
  make_coll "shared@$dominio" contacts "Condivisa ($dominio)" VADDRESSBOOK
  make_coll "shared@$dominio" calendar "Calendario condiviso ($dominio)" VCALENDAR
done
