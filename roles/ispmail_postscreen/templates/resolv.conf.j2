{{ ansible_managed | comment }}
# Resolver ricorsivo locale (unbound, ruolo ispmail_postscreen): le query
# alle DNSBL richiedono un resolver proprio, Spamhaus non risponde a
# quelli pubblici (8.8.8.8, 1.1.1.1, ...).
{% if ispmail_postscreen_search_domain %}
search {{ ispmail_postscreen_search_domain }}
{% endif %}
nameserver 127.0.0.1
